fewshot_split: test
fewshot_config:
  sampler: first_n

output_type: generate_until
metric_list:
  - metric: !function utils.exact_match_normalized_label
    aggregation: mean
    higher_is_better: true
filter_list:
  - name: extract_answer
    filter:
      - function: custom
        filter_fn: !function utils.extract_bracketed_label


doc_to_text: !function utils.doc_to_text
doc_to_target: correct_answer
process_docs: !function utils.add_options_with_text

metadata:
  version: 0.0

generation_kwargs:
  until:
    - <end_of_turn>
    - <eos>
    - </s>
    - <|end_of_text|>
    - <|eot_id|>
    - <|endoftext|>
    - <|im_end|>
  do_sample: false
