dataset_path: json
test_split: train
output_type: generate_until
doc_to_text: "Please read the following text and answer the question below.\n\n<text>\n\
  {{context_en}}\n</text>\n\nWhat is the correct answer to this question: {{question_en.strip()}}\n\
  Choices:\n(A) {{choice_A_en}}\n(B) {{choice_B_en}}\n(C) {{choice_C_en}}\n(D) {{choice_D_en}}\n\
  \n# Instruction\nReturn only the final answer as the option letter inside double
  square brackets.\nValid outputs are only:\n[[A]], [[B]], [[C]], or [[D]]\n\nAnswer:"
doc_to_target: answer
process_docs: !function utils.add_options_with_text_en
metric_list:
  - metric: !function utils.exact_match_normalized_label
    aggregation: mean
    higher_is_better: true
metadata:
  version: 0.0
generation_kwargs:
  until:
    - <end_of_turn>
    - <|im_end|>
    - <eos>
    - </s>
    - <|end_of_text|>
    - <|eot_id|>
    - <|endoftext|>
  do_sample: false
filter_list:
  - name: extract_answer
    filter:
      - function: custom
        filter_fn: !function utils.extract_bracketed_label
